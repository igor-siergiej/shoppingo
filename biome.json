{
  "extends": ["@imapps/biome-config/base"],
  "files": {
    "experimentalScannerIgnores": [".github/workflows-utils"],
    "includes": ["**", "!.design-sync", "!packages/web/.design-sync-fonts", "!packages/web/.design-sync-theme"]
  },
  "linter": {
    "rules": {
      "a11y": {
        "useSemanticElements": "warn"
      },
      "correctness": {
        "useUniqueElementIds": "warn"
      }
    }
  }
}
