{
  "name": "shoppingo",
  "version": "1.21.6",
  "private": true,
  "repository": "https://github.com/igor-siergiej/shoppingo",
  "author": "Igor Siergiej <igorsiergiej@gmail.com>",
  "scripts": {
    "start:web": "bun run --filter @shoppingo/web start",
    "start:web:with-mock": "dotenv -e .env -- bun run --filter @shoppingo/web start:with-mock",
    "start:api": "dotenv -e .env -- bun run --filter @shoppingo/api start",
    "start": "bun run start:web & bun run start:api",
    "start:with-mock": "bun run start:web:with-mock & bun run start:api",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe .",
    "format": "biome format --write ."
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@imapps/biome-config": "0.5.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@vitest/ui": "^3.2.4",
    "dotenv-cli": "^10.0.0",
    "semantic-release": "^24.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.3.9",
  "lint-staged": {
    "*.{ts,tsx,json}": "biome check --fix --unsafe"
  },
  "dependencies": {
    "sonner": "^2.0.7"
  }
}
